#!/usr/bin/env python3

import os
import re
import sys
import tempfile
import argparse
import shutil
import subprocess
from functools import cached_property


class ReGit:
    def __init__(self):
        result = self._start()
        if result:
            sys.exit(result)

    GIT_COMMANDS = ["up", "scan", "grab", "lgrab", "sync", "deps"]
    COMMANDS = GIT_COMMANDS + ["install", "uninstall", "self"]

    def _start(self):
        basename = os.path.basename(sys.argv[0])
        if basename.startswith("git-"):
            command = basename[4:]
            if command not in self.COMMANDS:
                self.aux.error("regit: unknown command '{}'".format(command))
                return 1
            sys.argv = [sys.argv[0], command] + sys.argv[1:]

        self.args, _ = self.parser.parse_known_args()
        command = self.args.command

        if not isinstance(command, str) or command.startswith("_"):
            self.parser.print_help()
            return 1
        if command not in self.COMMANDS:
            self.aux.error("regit: unknown command '{}'".format(command))
            return 1

        if self.args.start_path:
            os.chdir(self.args.start_path)
        return getattr(self, command)()

    def install(self):
        regit_path = os.path.realpath(__file__)
        bin_dir = os.path.dirname(os.path.abspath(sys.argv[0]))
        for cmd in self.GIT_COMMANDS:
            link = os.path.join(bin_dir, "git-" + cmd)
            if os.path.exists(link) or os.path.islink(link):
                os.remove(link)
            os.symlink(regit_path, link)
            self.aux.notice("created {} → {}".format(link, regit_path))
        return 0

    def uninstall(self):
        bin_dir = os.path.dirname(os.path.abspath(sys.argv[0]))
        for cmd in self.GIT_COMMANDS:
            link = os.path.join(bin_dir, "git-" + cmd)
            if os.path.islink(link):
                os.remove(link)
                self.aux.notice("removed {}".format(link))
        return 0

    def self(self):
        return self.git.pull(os.path.dirname(__file__))

    def up(self):
        err_pull = self.git.do("pull --rebase")
        err_deps = self.deps()
        return err_pull if err_pull else err_deps

    def deps(self):
        result = 0
        for path in self.config.repos:
            if not os.path.exists(path):
                err = self.git.clone("", path)
            else:
                err = self.repeat.up(path)
            if err and not result:
                result = err
        return result

    def lgrab(self):
        self.config._defaultSource = self.config.defaultPrivateSource
        return self.grab()

    def grab(self):
        return self.cloner.clone(self.args.repo, self.args.path)

    def scan(self):
        return self.scanner.scan()

    def sync(self):
        if not self.args.path:
            self.parser.print_subcommand_help("sync")
            return 1
        return self.syncer.sync(self.args.path)

    @cached_property
    def aux(self):
        return Aux(self)

    @cached_property
    def git(self):
        return Git(self)

    @cached_property
    def config(self):
        return Config(self)

    @cached_property
    def cloner(self):
        return Cloner(self)

    @cached_property
    def scanner(self):
        return Scanner(self)

    @cached_property
    def syncer(self):
        return Syncer(self)

    @cached_property
    def parser(self):
        return ArgParser(self)

    @cached_property
    def repeat(self):
        return Repeat(self)


class Component:
    def __init__(self, regit):
        self.regit = regit

    @property
    def aux(self):
        return self.regit.aux

    @property
    def git(self):
        return self.regit.git

    @property
    def config(self):
        return self.regit.config

    @property
    def repeat(self):
        return self.regit.repeat


class Repeat(Component):
    def up(self, path):
        return self.do("up", path)

    def deps(self, path):
        return self.do("deps", path)

    def do(self, command, path):
        if not path:
            self.aux.die("path not given for repeat")
        if path == ".":
            return self.aux.do_regit(command)
        cwd = os.getcwd()
        os.chdir(path)
        try:
            self.aux.warning(os.getcwd())
            return self.aux.do_regit(command)
        finally:
            os.chdir(cwd)


class Cloner(Component):
    def clone(self, repo, path):
        if path == ".git":
            return self.clone2git(repo)
        if path == ".":
            result = self.clone2dot(repo)
        else:
            result = self.git.clone(repo, path)
        if result:
            return result
        return self.repeat.deps(path if path else self.config.repo2path(repo))

    def clone2git(self, repo):
        if os.path.exists(".git"):
            self.aux.die("git repository already exists in " + os.getcwd())

        repo = self.config.path2repo_or_die(repo)
        tmp = tempfile.mkdtemp()

        try:
            result = self.git.do("clone --no-checkout {} {}".format(repo, tmp))
            if result:
                return result
            shutil.move(os.path.join(tmp, ".git"), ".git")
            return 0
        finally:
            shutil.rmtree(tmp, ignore_errors=True)

    def clone2dot(self, repo):
        if os.path.exists(".git"):
            self.aux.die("git repository already exists in " + os.getcwd())

        cwd = os.getcwd()
        tmp = tempfile.mkdtemp()

        try:
            result = self.git.clone(repo, tmp)
            if result:
                return result
            return self.aux.system("rsync -a --ignore-existing {tmp}/ {cwd}/".format(tmp=tmp, cwd=cwd))
        finally:
            shutil.rmtree(tmp, ignore_errors=True)


class Scanner(Component):
    WINDMILL = ["-", "\\", "|", "/"]
    GREETING = "Scanning repos... "
    SKIPS = (
        "On branch",
        "HEAD detached",
        "Your branch is up-to-date",
        "Your branch is up to date",
        "nothing to commit, working directory clean",
        "nothing to commit, working tree clean",
    )
    AHEAD = "Your branch is ahead"
    BEHIND = "Your branch is behind"
    FETCHES = (AHEAD, BEHIND)

    def scan(self):
        self.dir = os.getcwd()
        repos = self.find_repos()
        stats = self.check_repos(repos)
        self.output_stats(stats)

    def find_repos(self):
        self.aux.tprint(self.GREETING)
        sys.stdout.flush()
        result = subprocess.run(["find", ".", "-name", ".git"],
            capture_output=True, text=True)
        return sorted(result.stdout.splitlines(keepends=True))

    def check_repos(self, repos):
        stats = {}
        no = 0
        prev = self.GREETING
        for dir in repos:
            dir = self.dir + "/" + dir[2:-6]
            msg = self.WINDMILL[no % 4] + " " + dir
            self.aux.tprint("\r" + msg.ljust(len(prev)))
            prev = msg
            no += 1
            status = self.check(dir)
            if status:
                stats[dir] = status
        self.aux.tprint("\r" + "".ljust(len(prev)) + "\r")
        return stats

    def output_stats(self, stats):
        cols = self.terminal_width()
        maxlen = 1
        for dir in stats:
            if len(dir) > maxlen:
                maxlen = len(dir)
        for dir in stats:
            status = stats[dir]
            avail = cols - maxlen - 3  # " - " separator
            if avail > 0 and len(status) > avail:
                status = status[: avail - 3] + "..."
            print("{} - {}".format(dir.ljust(maxlen), self.aux.colored(status, "yellow")))

    def terminal_width(self):
        try:
            return os.get_terminal_size().columns
        except (AttributeError, ValueError, OSError):
            return 120

    def check(self, dir):
        args = self.regit.args
        cwd = os.getcwd()
        os.chdir(dir)
        try:
            status = self.check_status()
            if status is None and not args.force:
                return
            if status is not None and args.skip_behind and status.startswith(self.BEHIND):
                return
            if args.force or (status is not None and status.startswith(self.FETCHES)):
                quiet = "" if args.verbose else " --quiet"
                self.git.do(args.pull + quiet, not args.verbose)
                status = self.check_status()
                if status is None:
                    return
            return status
        finally:
            os.chdir(cwd)

    def check_status(self):
        status = None
        result = subprocess.run(["git", "status"], capture_output=True, text=True)
        for line in result.stdout.splitlines():
            status = line.strip()
            if status and not self.is_skippable(status):
                status = status.strip(".,:")
                if status == "Untracked files":
                    files = self.list_untracked()
                    if files:
                        return "untracked: " + " ".join(files)
                return status
        return None

    def list_untracked(self):
        output = subprocess.check_output(["git", "ls-files", "--others", "--exclude-standard"]).decode("utf-8").strip()
        if not output:
            return []
        return output.split("\n")

    def is_skippable(self, status):
        if status.startswith("# "):
            status = status[2:]
        return status.startswith(self.SKIPS)


class Syncer(Component):
    def sync(self, dest):
        changed = subprocess.check_output(["git", "diff", "--name-only"]).decode("utf-8").strip().split("\n")
        untracked = subprocess.check_output(["git", "ls-files", "--others", "--exclude-standard"]).decode("utf-8").strip().split("\n")
        files = "\n\t".join(filter(None, changed + untracked))
        if not files:
            return None
        return self.aux.system(f'echo "\n\t{files}\n" | cut -c2- | rsync -a --files-from=- . {dest}')


class Config(Component):
    def __init__(self, regit):
        Component.__init__(self, regit)
        self.repos = {}
        self.knownRepos = {}
        self.knownSources = {}
        self.load()

    def load(self):
        self.load_global("~/.config/regit/config")
        self.load_local(".regit")

    def load_global(self, path):
        path = os.path.expanduser(path)
        if os.path.exists(path):
            data = self.read_file(path)
            if "known-repos" in data:
                self.knownRepos.update(data["known-repos"])
            if "known-sources" in data:
                self.knownSources.update(data["known-sources"])
            if "includes" in data:
                for _, file in data["includes"].items():
                    self.load_global(file)

    def load_local(self, path):
        if os.path.exists(path):
            data = self.read_file(path)
            if "repos" in data:
                self.repos.update(data["repos"])
            if "known-repos" in data:
                self.knownRepos.update(data["known-repos"])
            if "known-sources" in data:
                self.knownSources.update(data["known-sources"])

    def read_file(self, path):
        with open(path, "r", encoding="utf-8") as file:
            lines = file.readlines()
        section = ""
        result = {}
        for line in lines:
            line = line.strip()
            if not line:
                continue
            check = re.search(r"^\[(.+)\]$", line)
            if check:
                section = check.group(1)
                if section not in result:
                    result[section] = {}
                continue
            check = re.search(r"^\s*(.+?)\s*=\s*(.+)\s*$", line)
            if check:
                result[section][check.group(1)] = check.group(2)
                continue
            result[section][line] = line
        return result

    def repo2path(self, repo):
        url = self.path2repo_or_die(repo)
        return os.path.basename(url)

    def path2repo_or_die(self, path):
        repo = self.repath2repo(path)
        if repo:
            return repo
        parts = path.split(os.path.sep)
        if len(parts) < 2:
            path = os.path.basename(os.getcwd()) + "/" + path
        return self.defaultSource + path

    def repath2repo(self, path, _seen=None):
        if _seen is None:
            _seen = set()
        if path in _seen:
            return path
        _seen.add(path)
        repo = self.source2repo(path)
        if not repo:
            repo = self.path2repo(path)
        if repo == path:
            return repo
        return self.repath2repo(repo, _seen)

    def path2repo(self, path):
        repo = self.source2repo(path)
        if repo:
            return repo
        if self.is_repo_url(path):
            return path
        repo = self.repos.get(path)
        if repo and repo != path:
            return repo
        if path not in self.knownRepos:
            parts = path.split(os.path.sep)
            if len(parts) < 2:
                return ""
            parts.pop(0)
            return self.path2repo(os.path.sep.join(parts))
        return self.knownRepos[path]

    def source2repo(self, path):
        check = self.is_repo_with_source(path)
        if check is None:
            return False
        source = check.group(1)
        if source not in self.knownSources:
            return False
        return self.knownSources[source] + check.group(2)

    def is_repo_with_source(self, path):
        return re.match(r"^([\w.-]+):([\w.-]+/?[\w.-]*)$", path)

    def is_repo_url(self, repo):
        return ":" in repo or "@" in repo

    @property
    def defaultSource(self):
        if not hasattr(self, "_defaultSource"):
            setattr(self, "_defaultSource", self.defaultPublicSource)
        return getattr(self, "_defaultSource")

    @property
    def defaultPublicSource(self):
        return self.knownSources.get("public", self.knownSources.get("github", "git@github.com:"))

    @property
    def defaultPrivateSource(self):
        return self.knownSources.get("private", self.knownSources.get("gitlab", "git@gitlab.com:"))


class Git(Component):
    def do(self, command, quiet=False):
        return self.aux.system("git " + command, quiet)

    def clone(self, repo, path):
        repo = self.config.path2repo_or_die(repo if repo else path)
        return self.do("clone {} {}".format(repo, path))

    def pull(self, path):
        return self.do("-C {} pull --rebase".format(path))


class Aux(Component):
    def do_regit(self, command):
        return self.system(__file__ + " " + command)

    def system(self, command, quiet=False):
        if not quiet:
            self.notice("> " + command.rstrip())
        result = subprocess.call(command, shell=True)
        if result:
            self.error("! failed")
        return result

    def die(self, text="die", color="error"):
        self.error(text)
        raise Exception(text)

    def error(self, text, color="error"):
        print(self.colored(text, color, sys.stderr.isatty()), file=sys.stderr)

    def warning(self, text, color="warning"):
        print(self.colored(text, color))

    def notice(self, text, color="notice"):
        print(self.colored(text, color))

    def tprint(self, text):
        if sys.stdout.isatty():
            print(text, end="")

    TYPES = {
        "notice": "white",
        "success": "green",
        "warning": "yellow",
        "error": "red",
    }
    COLORS = {
        "normal": "",
        "white": "\033[97m",
        "cyan": "\033[96m",
        "magenta": "\033[95m",
        "blue": "\033[94m",
        "yellow": "\033[93m",
        "green": "\033[92m",
        "red": "\033[91m",
        "end": "\033[0m",
    }

    def colored(self, text, color, apply=None):
        if apply is None:
            apply = sys.stdout.isatty()
        if not apply:
            return text
        if color in self.TYPES:
            color = self.TYPES[color]
        return self.COLORS[color] + text + self.COLORS["end"]


class ArgParser(Component):
    VERSION = "0.1.0"

    def __init__(self, regit):
        self.regit = regit
        self.parser = MyArgumentParser(description="Repeated Git version " + self.VERSION)
        self.add_base()
        self.add_clone("grab")
        self.add_clone("lgrab")
        self.add_deps()
        self.add_install()
        self.add_scan()
        self.add_sync()
        self.add_self()
        self.add_up()

    def add_base(self):
        self.parser.add_argument("-C", dest="start_path", help="start at given directory")
        self.parser.add_argument("-V", "--version", action="version", version="%(prog)s " + self.VERSION)
        self.subparsers = self.parser.add_subparsers(dest="command", help="sub-command name")

    def add_clone(self, name):
        desc = "Clone with URL resolution from ~/.config/regit/config. " \
               "Use '.' to rsync into current directory, '.git' for metadata only."
        parser = self.subparsers.add_parser(name, description=desc,
            help="clone with URL resolution (use . for cwd, .git for metadata only)")
        parser.add_argument("repo", help="repository url or name")
        parser.add_argument("path", nargs="?", default="",
            help="path, '.' to rsync into cwd, '.git' for metadata only")

    def add_deps(self):
        self.subparsers.add_parser("deps", description="Pull dependencies listed in .regit config.",
            help="update dependencies")

    def add_install(self):
        self.subparsers.add_parser("install",
            description="Create git-* symlinks in the same directory as the regit binary "
            "so commands work as 'git up', 'git scan', etc.",
            help="create git-* symlinks")
        self.subparsers.add_parser("uninstall",
            description="Remove git-* symlinks created by 'regit install'.",
            help="remove git-* symlinks")

    def add_scan(self):
        parser = self.subparsers.add_parser("scan",
            description="Recursively scan directory tree for git repos that have "
            "uncommitted changes, unpushed commits, or are behind remote.",
            help="recursively scan dirs for repos requiring attention")
        parser.add_argument("-f", "--force", action="store_true", help="force")
        parser.add_argument("-v", "--verbose", action="store_true", help="be verbose")
        parser.add_argument("-b", "--skip-behind", action="store_true",
            help="skip 'Your branch is behind'")
        parser.add_argument("-p", "--pull", action="store_const", const="pull",
            default="fetch", help="pull instead of fetch")

    def add_sync(self):
        parser = self.subparsers.add_parser("sync",
            description="Rsync only git-changed and untracked files to the given destination path.",
            help="rsync only git changed and untracked files to given path")
        parser.add_argument("path", help="path to rsync to")

    def add_self(self):
        self.subparsers.add_parser("self",
            description="Update regit to the latest version by pulling from the git repository.",
            help="update itself to the latest version")

    def add_up(self):
        self.subparsers.add_parser("up",
            description="Pull current repo with rebase and recursively update dependencies.",
            help="update current repo and dependencies")

    def parse_known_args(self):
        return self.parser.parse_known_args()

    def print_help(self):
        return self.parser.print_help()

    def print_subcommand_help(self, name):
        return self.subparsers.choices[name].print_help()


class MyArgumentParser(argparse.ArgumentParser):
    def error(self, message):
        self.print_usage(sys.stderr)
        sys.stderr.write("error: {}\n".format(message))
        sys.exit(2)


if __name__ == "__main__":
    ReGit()
